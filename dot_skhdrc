# focus
alt - h : yabai -m window --focus west
alt - j : yabai -m window --focus south
alt - k : yabai -m window --focus north
alt - l : yabai -m window --focus east

# swap
alt + shift - h : yabai -m window --swap west
alt + shift - j : yabai -m window --swap south
alt + shift - k : yabai -m window --swap north
alt + shift - l : yabai -m window --swap east

# warp (resplits) 
alt + ctrl - h : yabai -m window --warp west
alt + ctrl - j : yabai -m window --warp south
alt + ctrl - k : yabai -m window --warp north
alt + ctrl - l : yabai -m window --warp east

# rotate
alt + shift - o : yabai -m space --rotate 90
alt + shift - u : yabai -m space --rotate 270

# mirror
alt + shift - x : yabai -m space --mirror x-axis
alt + shift - y : yabai -m space --mirror y-axis

# resize (-, =)
alt + shift - m : yabai -m window --ratio rel:-0.05
alt + shift - p : yabai -m window --ratio rel:0.05

# full screen
alt - m : yabai -m window --toggle native-fullscreen
alt + shift - z : yabai -m window --toggle zoom-fullscreen

# balance, float, restart
alt + shift - b : yabai -m space --balance
alt + shift - f : yabai -m window --toggle float
alt + shift - s : yabai --restart-service

# workspaces
alt - 1 : yabai -m space --focus 1
alt - 2 : yabai -m space --focus 2
alt - 3 : yabai -m space --focus 3
alt - 4 : yabai -m space --focus 4
alt - 5 : yabai -m space --focus 5
alt - 6 : yabai -m space --focus 6
alt - 7 : yabai -m space --focus 7
alt - 8 : yabai -m space --focus 8
alt - 9 : yabai -m space --focus 9

# move window to workspace (auto-creates space if it doesn't exist)
alt + shift - 1 : yabai -m window --space 1 || (yabai -m space --create && yabai -m window --space 1)
alt + shift - 2 : yabai -m window --space 2 || (yabai -m space --create && yabai -m window --space 2)
alt + shift - 3 : yabai -m window --space 3 || (yabai -m space --create && yabai -m window --space 3)
alt + shift - 4 : yabai -m window --space 4 || (yabai -m space --create && yabai -m window --space 4)
alt + shift - 5 : yabai -m window --space 5 || (yabai -m space --create && yabai -m window --space 5)
alt + shift - 6 : yabai -m window --space 6 || (yabai -m space --create && yabai -m window --space 6)
alt + shift - 7 : yabai -m window --space 7 || (yabai -m space --create && yabai -m window --space 7)
alt + shift - 8 : yabai -m window --space 8 || (yabai -m space --create && yabai -m window --space 8)
alt + shift - 9 : yabai -m window --space 9 || (yabai -m space --create && yabai -m window --space 9)
